# ===========================================
# EstaMind — Ortam Değişkenleri
# ===========================================
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# Canlıda (production) hosting panelinden veya CI/CD ile ayarlayın.

# --- Uygulama ---
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=EstaMind

# --- Kimlik Doğrulama (Supabase veya NextAuth) ---
# Supabase kullanıyorsanız:
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Sunucu tarafında kullanılacak (API route'ları):
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# NextAuth kullanıyorsanız:
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# --- Yapay Zeka / Analiz API ---
# İstemci analizi sunucu route üzerinden çalıştırmak için (çerez gerekir):
# NEXT_PUBLIC_ANALYSIS_VIA_API=true
# OpenAI (fiyat tahmini, strateji metni) — yalnızca sunucuda; istemciye eklenmez:
OPENAI_API_KEY=sk-...
# Alternatif: Replicate veya kendi FastAPI endpoint'iniz
# REPLICATE_API_TOKEN=...
# ANALYSIS_API_URL=https://your-analysis-service.com/v1

# --- Ödeme (iyzico / PayTR) ---
IYZICO_API_KEY=...
IYZICO_SECRET_KEY=...
IYZICO_BASE_URL=https://api.iyzipay.com
# PayTR: PAYTR_MERCHANT_ID=... PAYTR_MERCHANT_KEY=... PAYTR_MERCHANT_SALT=...

# --- Veritabanı (Supabase zaten URL ile geliyor; ayrı Postgres kullanıyorsanız) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- E-posta (opsiyonel: kayıt onayı, şifre sıfırlama) ---
# RESEND_API_KEY=...
# SMTP_HOST=... SMTP_USER=... SMTP_PASS=...

# --- İzleme / Hata takibi (opsiyonel) ---
# SENTRY_DSN=...
# NEXT_PUBLIC_SENTRY_DSN=...
